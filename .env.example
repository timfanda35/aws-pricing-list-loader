POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aws_pricing
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SSL / GCP Cloud SQL (optional — omit for plain TCP)
# For local dev: run scripts/gen-dev-certs.sh first, then use docker-compose.ssl.yml
# POSTGRES_SSL_MODE=verify-ca
# POSTGRES_SSL_ROOTCERT=./certs/server-ca.pem
# POSTGRES_SSL_CERT=./certs/client-cert.pem
# POSTGRES_SSL_KEY=./certs/client-key.pem
